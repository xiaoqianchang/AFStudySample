<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data></data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".ui.MainActivity">

        <!-- Global controls: WIFI -->
        <LinearLayout
            android:id="@+id/row_global_wifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_wifi" />

            <RadioGroup
                android:id="@+id/rg_wifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_wifi_none"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="不设置" />
                <RadioButton
                    android:id="@+id/rb_wifi_allow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="允许" />
                <RadioButton
                    android:id="@+id/rb_wifi_deny"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="拒绝" />
            </RadioGroup>
        </LinearLayout>

        <!-- Global controls: MOBILE -->
        <LinearLayout
            android:id="@+id/row_global_mobile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_mobile" />

            <RadioGroup
                android:id="@+id/rg_mobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_mobile_none"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="不设置" />
                <RadioButton
                    android:id="@+id/rb_mobile_allow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="允许" />
                <RadioButton
                    android:id="@+id/rb_mobile_deny"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="拒绝" />
            </RadioGroup>
        </LinearLayout>

        <!-- Global controls: ALL -->
        <LinearLayout
            android:id="@+id/row_global_all"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_all" />

            <RadioGroup
                android:id="@+id/rg_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_all_none"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="不设置" />
                <RadioButton
                    android:id="@+id/rb_all_allow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="允许" />
                <RadioButton
                    android:id="@+id/rb_all_deny"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="拒绝" />
            </RadioGroup>
        </LinearLayout>

        <!-- Header for list columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="应用名称"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_wifi" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_mobile" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</layout>